# SPEACE Environment Variables
# Copia questo file in .env e configura i valori

# Anthropic API Key (necessaria per Team Scientifico LLM)
# Ottieni la tua chiave su: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-your-api-key-here

# Email per status report (opzionale)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=speace@rigene.eu

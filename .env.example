# SPEACE / TINA Testbed environment variables
# Copy this file to .env and fill with your actual API keys

# Data Sources (optional, for live data collection)
NASA_API_KEY=your_nasa_earthdata_key_here
NOAA_API_KEY=your_noaa_key_here
WORLD_BANK_API_KEY=your_key_here
WHO_API_KEY=your_key_here

# LLM / AI (if using external services)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# OpenClaw typically uses local models or OpenRouter; set if using cloud

# Redis (for multi-framework communication)
REDIS_URL=redis://localhost:6379

# Blockchain / Wallet (read-only for monitoring)
ETH_RPC_URL=https://mainnet.infura.io/v3/your_project_id
WALLET_ADDRESS=0xYourReadOnlyWalletAddress

# GitHub (for automated issues/PR management)
GITHUB_TOKEN=ghp_...

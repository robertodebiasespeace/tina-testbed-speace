# ============================================================
# SPEACE – .gitignore
# ============================================================

# Secrets e configurazione locale
.env
*.key
*.pem
*.p12

# Script git con token (eliminare dopo l'uso)
git-push-github.ps1
GIT-PUSH-NOW.bat
git_push_github.py
PUSH-NOW.bat

# Log push
git_push_log.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
venv_ml/
env/
.venv/
pip-log.txt

# Log (mantieni struttura, non i contenuti)
logs/*.log
logs/status_reports/
!logs/.gitkeep

# Snapshot (generati a runtime, non versionare)
safeproactive/snapshots/*/
!safeproactive/snapshots/.gitkeep

# Memory episodica (generata a runtime)
memory/episodic/
memory/world_model.json
!memory/.gitkeep
!memory/MEMORY.md

# WAL log (generato a runtime)
safeproactive/WAL.log

# Output agenti (generati a runtime)
scientific-team/outputs/daily_brief_*.md

# Claude Code
.claude/

# Notebook e IDE
.jupyter/
*.ipynb
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Test coverage
.coverage
htmlcov/
.pytest_cache/
pytest-cache-files-*/

# Temp
*.tmp
*.bak
*.orig

# Output di comandi finiti accidentalmente in redirezione (non versionare)
/1
/2
/loop

# Materiale di riferimento (PDF/libri) — troppo pesante per il repo
Organismic AI Initiative/
*.pdf

# Docker / container

# Vendored frameworks
vendor/
MultiFramework/agpt/

# Runtime data
data/learning_state.json
data/speace_live_state.json
data/metalearner_state.json
data/ml_integration_state.json
data/rl_models/
vector_data/
speace_status.json
speace_world_model_test_report.json
